<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://www.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>com.example</groupId>
  <artifactId>protogemcouch</artifactId>
  <version>1.5.0</version>
  <packaging>jar</packaging>

  <name>protogemcouch</name>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <maven.compiler.release>17</maven.compiler.release>

    <junit.jupiter.version>5.10.2</junit.jupiter.version>
    <mockito.version>5.12.0</mockito.version>

    <maven.compiler.plugin.version>3.11.0</maven.compiler.plugin.version>
    <maven.surefire.plugin.version>3.2.5</maven.surefire.plugin.version>
    <maven.failsafe.plugin.version>3.2.5</maven.failsafe.plugin.version>
    <maven.shade.plugin.version>3.5.2</maven.shade.plugin.version>
    <exec.maven.plugin.version>3.2.0</exec.maven.plugin.version>
    <!-- 0.8.13 supports Java 23+ class files / runtime (build + CI run on JDK 17–23). -->
    <jacoco.plugin.version>0.8.13</jacoco.plugin.version>
    <!--
      Unit-test line-coverage floor for production code (a ratchet, not a target). Scoped to the
      unit-testable surface: dev-only packages (tools/probe/benchmark/samples) are excluded, and the
      wire/handler paths that are only exercised by the Docker-backed integration suite are NOT
      counted here (JaCoCo on the test JVM cannot see the shim running in its container). Raise this
      as coverage improves; never lower it without a written reason. See docs/TEST_STRATEGY.md.
    -->
    <jacoco.line.coverage.min>0.60</jacoco.line.coverage.min>

    <slf4j.version>2.0.9</slf4j.version>
    <log4j.version>2.17.2</log4j.version>
    <opentelemetry.version>1.43.0</opentelemetry.version>
    <couchbase.java.client.version>3.7.8</couchbase.java.client.version>
    <!--
      Latest 1.15.x that is a clean drop-in. To move up within 1.15, bump this one property (the
      geode-core + test-scoped geode-cq both follow it) and the geode/docker-compose.yml image tag in
      lockstep. Note two ceilings before going past 1.15.1:
        * geode 1.15.2+ pulls log4j-api 2.25.4 transitively, which is incompatible with the pinned
          log4j-core ${log4j.version} (2.17.2) and crashes the client at startup
          (NoSuchMethodError LoaderUtil.getClassLoaders) — bump log4j too if you go there.
        * Apache publishes Geode Docker images only through 1.15.1, so the capture server
          (geode/docker-compose.yml, dev tools only) cannot match a newer client.
    -->
    <geode.version>1.15.1</geode.version>
    <netty.version>4.1.118.Final</netty.version>

    <!-- Docker Compose automation settings -->
    <docker.compose.file>docker-compose.yml</docker.compose.file>
    <skipDockerCompose>false</skipDockerCompose>
  </properties>

  <dependencyManagement>
    <dependencies>
      <!-- Align all OpenTelemetry artifacts to one version. -->
      <dependency>
        <groupId>io.opentelemetry</groupId>
        <artifactId>opentelemetry-bom</artifactId>
        <version>${opentelemetry.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
    </dependencies>
  </dependencyManagement>

  <dependencies>
    <dependency>
      <groupId>com.couchbase.client</groupId>
      <artifactId>java-client</artifactId>
      <version>${couchbase.java.client.version}</version>
    </dependency>

    <!--
      Distributed tracing (off by default). The API is used for manual operation / backend spans; the
      SDK + OTLP exporter + autoconfigure are initialized from OTEL_* env at startup (no endpoint ->
      a no-op tracer, zero overhead). See com.protogemcouch.observability.Tracing.
    -->
    <dependency>
      <groupId>io.opentelemetry</groupId>
      <artifactId>opentelemetry-api</artifactId>
    </dependency>
    <dependency>
      <groupId>io.opentelemetry</groupId>
      <artifactId>opentelemetry-sdk</artifactId>
    </dependency>
    <dependency>
      <groupId>io.opentelemetry</groupId>
      <artifactId>opentelemetry-exporter-otlp</artifactId>
    </dependency>
    <dependency>
      <groupId>io.opentelemetry</groupId>
      <artifactId>opentelemetry-sdk-extension-autoconfigure</artifactId>
    </dependency>

    <dependency>
      <groupId>org.apache.geode</groupId>
      <artifactId>geode-core</artifactId>
      <version>${geode.version}</version>
    </dependency>

    <!--
      Client-side Continuous Query engine. The shim does NOT use this (it matches with its own
      OqlQuery and speaks the CQ wire protocol directly); it is test-scoped so the integration test
      client can register CQs (QueryService.newCq needs CqServiceImpl at runtime, which lives here).
    -->
    <dependency>
      <groupId>org.apache.geode</groupId>
      <artifactId>geode-cq</artifactId>
      <version>${geode.version}</version>
      <scope>test</scope>
    </dependency>

    <dependency>
      <groupId>io.netty</groupId>
      <artifactId>netty-all</artifactId>
      <version>${netty.version}</version>
    </dependency>

    <dependency>
      <groupId>org.slf4j</groupId>
      <artifactId>slf4j-simple</artifactId>
      <version>${slf4j.version}</version>
    </dependency>

    <dependency>
      <groupId>org.apache.logging.log4j</groupId>
      <artifactId>log4j-core</artifactId>
      <version>${log4j.version}</version>
    </dependency>

    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <version>${junit.jupiter.version}</version>
      <scope>test</scope>
    </dependency>

    <dependency>
      <groupId>org.mockito</groupId>
      <artifactId>mockito-core</artifactId>
      <version>${mockito.version}</version>
      <scope>test</scope>
    </dependency>

    <dependency>
      <groupId>org.mockito</groupId>
      <artifactId>mockito-junit-jupiter</artifactId>
      <version>${mockito.version}</version>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>${maven.compiler.plugin.version}</version>
        <configuration>
          <release>${maven.compiler.release}</release>
        </configuration>
      </plugin>

      <!-- Unit tests only. Integration tests are excluded here. -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>${maven.surefire.plugin.version}</version>
        <configuration>
          <useModulePath>false</useModulePath>
          <!-- @{argLine} carries the JaCoCo agent set by jacoco:prepare-agent (else just our flag). -->
          <argLine>@{argLine} -Dnet.bytebuddy.experimental=true</argLine>

          <!-- Exclude JUnit 5 @Tag("integration") tests from mvn test. -->
          <excludedGroups>integration</excludedGroups>

          <includes>
            <include>**/*Test.java</include>
          </includes>

          <excludes>
            <exclude>**/*IT.java</exclude>
            <exclude>**/*IntegrationTest.java</exclude>
          </excludes>
        </configuration>
      </plugin>

      <!--
        Code-coverage measurement + gate (unit tests / surefire only). prepare-agent injects the
        JaCoCo agent into the surefire JVM via @{argLine}; report writes target/site/jacoco; check
        enforces the line-coverage floor on production code. Dev-only packages and the wire/handler
        paths that only the Docker-backed integration suite exercises are excluded — see the
        jacoco.line.coverage.min property note and docs/TEST_STRATEGY.md.
      -->
      <plugin>
        <groupId>org.jacoco</groupId>
        <artifactId>jacoco-maven-plugin</artifactId>
        <version>${jacoco.plugin.version}</version>
        <configuration>
          <excludes>
            <!-- Dev/ops tooling, not shipped request-path code. -->
            <exclude>com/protogemcouch/tools/**</exclude>
            <exclude>com/protogemcouch/probe/**</exclude>
            <exclude>com/protogemcouch/benchmark/**</exclude>
            <exclude>com/protogemcouch/samples/**</exclude>
          </excludes>
        </configuration>
        <executions>
          <execution>
            <id>jacoco-prepare-agent</id>
            <goals>
              <goal>prepare-agent</goal>
            </goals>
          </execution>
          <execution>
            <id>jacoco-report</id>
            <phase>test</phase>
            <goals>
              <goal>report</goal>
            </goals>
          </execution>
          <execution>
            <id>jacoco-check</id>
            <phase>test</phase>
            <goals>
              <goal>check</goal>
            </goals>
            <configuration>
              <!--
                The gate measures the unit-testable surface. CouchbaseRepository is the live-Couchbase
                backend implementation: it is exercised end-to-end by the Docker-backed integration
                suite (mvn verify), but that runs against the shim inside its container, so JaCoCo on
                the surefire JVM cannot observe it (~1,600 lines that would otherwise be counted as
                "missed" forever). It is excluded from the gate but kept in target/site/jacoco so the
                gap stays visible. combine.children=append keeps the dev-only plugin-level excludes too.
              -->
              <excludes combine.children="append">
                <exclude>com/protogemcouch/couchbase/CouchbaseRepository.class</exclude>
                <exclude>com/protogemcouch/couchbase/CouchbaseRepository$*.class</exclude>
              </excludes>
              <rules>
                <rule>
                  <element>BUNDLE</element>
                  <limits>
                    <limit>
                      <counter>LINE</counter>
                      <value>COVEREDRATIO</value>
                      <minimum>${jacoco.line.coverage.min}</minimum>
                    </limit>
                  </limits>
                </rule>
              </rules>
            </configuration>
          </execution>
        </executions>
      </plugin>

      <!-- Build the runnable shaded jar before Docker Compose starts. -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-shade-plugin</artifactId>
        <version>${maven.shade.plugin.version}</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <createDependencyReducedPom>false</createDependencyReducedPom>
              <finalName>protogemcouch</finalName>
              <transformers>
                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                  <mainClass>com.protogemcouch.shim.RawShimServer</mainClass>
                  <manifestEntries>
                    <!--
                      The jar bundles multi-release dependencies (e.g. log4j-api ships a JDK9+
                      StackWalker implementation under META-INF/versions/9). Without this flag the
                      JVM ignores those versioned classes and falls back to the removed
                      sun.reflect.Reflection path, which breaks the Geode client (LogService) on
                      JDK 9+. Marking the shaded jar multi-release fixes that.
                    -->
                    <Multi-Release>true</Multi-Release>
                  </manifestEntries>
                </transformer>
              </transformers>
            </configuration>
          </execution>
        </executions>
      </plugin>

      <!-- Start and stop Docker Compose around integration tests. -->
      <plugin>
        <groupId>org.codehaus.mojo</groupId>
        <artifactId>exec-maven-plugin</artifactId>
        <version>${exec.maven.plugin.version}</version>
        <executions>
          <execution>
            <id>docker-compose-up</id>
            <phase>pre-integration-test</phase>
            <goals>
              <goal>exec</goal>
            </goals>
            <configuration>
              <skip>${skipDockerCompose}</skip>
              <executable>docker</executable>
              <workingDirectory>${project.basedir}</workingDirectory>
              <arguments>
                <argument>compose</argument>
                <argument>-f</argument>
                <argument>${docker.compose.file}</argument>
                <argument>up</argument>
                <argument>-d</argument>
                <argument>--build</argument>
              </arguments>
            </configuration>
          </execution>

          <execution>
            <id>docker-compose-down</id>
            <phase>post-integration-test</phase>
            <goals>
              <goal>exec</goal>
            </goals>
            <configuration>
              <skip>${skipDockerCompose}</skip>
              <executable>docker</executable>
              <workingDirectory>${project.basedir}</workingDirectory>
              <arguments>
                <argument>compose</argument>
                <argument>-f</argument>
                <argument>${docker.compose.file}</argument>
                <argument>down</argument>
                <argument>-v</argument>
              </arguments>
            </configuration>
          </execution>
        </executions>
      </plugin>

      <!-- Integration tests only. Run with mvn verify. -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-failsafe-plugin</artifactId>
        <version>${maven.failsafe.plugin.version}</version>
        <configuration>
          <useModulePath>false</useModulePath>
          <argLine>-Dnet.bytebuddy.experimental=true</argLine>

          <!--
            Fork a fresh JVM per integration test class. The Geode client cache /
            distributed system is a JVM-wide singleton whose SSL socket layer is initialized
            once; reusing a JVM across classes lets non-SSL state leak into the TLS test (and
            vice versa). One JVM per class keeps each class's client configuration isolated.
          -->
          <forkCount>1</forkCount>
          <reuseForks>false</reuseForks>

          <!-- Run only JUnit 5 @Tag("integration") tests during failsafe. -->
          <groups>integration</groups>

          <includes>
            <include>**/*IT.java</include>
            <include>**/*IntegrationTest.java</include>
          </includes>
        </configuration>
        <executions>
          <execution>
            <goals>
              <goal>integration-test</goal>
              <goal>verify</goal>
            </goals>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>