CB_CONNSTR=couchbase://couchbase
CB_USERNAME=Administrator
CB_PASSWORD=password
CB_BUCKET=test
CB_SCOPE=_default
CB_COLLECTION=_default
SHIM_PORT=40405
HEALTH_PORT=8081

# Optional inbound-frame safety limits (defensive caps against malformed/oversized frames).
# Defaults are used if unset or invalid. See docs/SECURITY.md.
# MAX_FRAME_BYTES=52428800
# MAX_FRAME_PARTS=100000

# Behavior on operation failure: "close" (default) drops the connection; "exception" replies
# with a Geode EXCEPTION frame and keeps the connection open (pending live-client validation).
# ERROR_RESPONSE_MODE=close