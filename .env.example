CB_CONNSTR=couchbase://couchbase
CB_USERNAME=Administrator
CB_PASSWORD=password
CB_BUCKET=test
CB_SCOPE=_default
CB_COLLECTION=_default
SHIM_PORT=40405
HEALTH_PORT=8081

# Optional inbound-frame safety limits (defensive caps against malformed/oversized frames).
# Defaults are used if unset or invalid. See docs/SECURITY.md.
# MAX_FRAME_BYTES=52428800
# MAX_FRAME_PARTS=100000

# Behavior on operation failure: "exception" (default) replies with a Geode EXCEPTION frame and
# keeps the connection open; "close" drops the connection. The exception path is validated against
# a live Geode client.
# ERROR_RESPONSE_MODE=exception

# Size of the executor pool that runs request handlers off the Netty event loop.
# HANDLER_THREADS=64

# Couchbase operation timeouts (milliseconds).
# CB_KV_TIMEOUT_MS=5000
# CB_CONNECT_TIMEOUT_MS=10000

# Connection lifecycle guards.
# CONNECTION_IDLE_TIMEOUT_SECONDS: close idle connections after N seconds (0 disables).
# MAX_CONNECTIONS: cap concurrent client connections (0 = unlimited).
# FIRST_REQUEST_TIMEOUT_SECONDS: close a connection that doesn't complete its first request in N
#   seconds (slowloris guard; not reset by trickled bytes; 0 disables).
# CONNECTION_IDLE_TIMEOUT_SECONDS=300
# MAX_CONNECTIONS=0
# FIRST_REQUEST_TIMEOUT_SECONDS=10

# Handler executor backpressure.
# HANDLER_MAX_PENDING_TASKS: per-handler-thread queue bound; once full, requests are shed and the
#   connection closed rather than growing the backlog unbounded (0 = unbounded).
# HANDLER_MAX_PENDING_TASKS=10000

# Inbound TLS on the Geode listener (off by default). When enabled, keystore path+password are
# required. TLS_CLIENT_AUTH=require enables mutual TLS (needs a truststore). See docs/SECURITY.md.
# TLS_ENABLED=false
# TLS_KEYSTORE_PATH=/certs/server-keystore.p12
# TLS_KEYSTORE_PASSWORD=changeit
# TLS_KEYSTORE_TYPE=PKCS12
# TLS_CLIENT_AUTH=none
# TLS_TRUSTSTORE_PATH=/certs/client-truststore.p12
# TLS_TRUSTSTORE_PASSWORD=changeit
# TLS_TRUSTSTORE_TYPE=PKCS12