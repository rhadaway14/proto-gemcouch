{
  "uid": "protogemcouch-overview-pro",
  "title": "ProtoGemCouch \u2014 Production Overview",
  "tags": [
    "protogemcouch",
    "overview"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timepicker": {},
  "refresh": "30s",
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Availability (success %)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(1 - sum(rate(protogemcouch_operation_errors_total[5m])) / clamp_min(sum(rate(protogemcouch_operation_requests_total[5m])), 1)) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 99
              },
              {
                "color": "green",
                "value": 99.9
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "p95 latency",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(protogemcouch_operation_latency_seconds_bucket[$__rate_interval]))) * 1000",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 100
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Requests / sec",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(protogemcouch_operation_requests_total[$__rate_interval]))",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Error rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(protogemcouch_operation_errors_total[$__rate_interval])) / clamp_min(sum(rate(protogemcouch_operation_requests_total[$__rate_interval])), 1) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Requests shed",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(protogemcouch_requests_shed_total)",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Host CPU",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[$__rate_interval])) * 100)",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "volkovlabs-echarts-panel",
      "title": "Service topology (live \u2014 real traffic & health)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "instant": true,
          "legendFormat": "reqps",
          "expr": "sum(rate(protogemcouch_operation_requests_total[$__rate_interval]))"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "B",
          "instant": true,
          "legendFormat": "pushed",
          "expr": "sum(rate(protogemcouch_pushdown_queries_total{result=\"pushed\"}[$__rate_interval]))"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "C",
          "instant": true,
          "legendFormat": "err",
          "expr": "sum(rate(protogemcouch_operation_errors_total[$__rate_interval])) / clamp_min(sum(rate(protogemcouch_operation_requests_total[$__rate_interval])), 1) * 100"
        }
      ],
      "options": {
        "renderer": "canvas",
        "editor": {
          "format": "auto",
          "height": 600
        },
        "themeEditor": {
          "config": "{}",
          "name": "default",
          "height": 0
        },
        "map": "none",
        "getOption": "\nconst s = (context.data && context.data.series) || [];\nfunction val(rid){const fr=s.find(f=>f.refId===rid);if(!fr)return 0;const vf=fr.fields.find(f=>f.type==='number');return (vf&&vf.values&&vf.values.length)?(vf.values[vf.values.length-1]||0):0;}\nconst reqps = val('A'), pushed = val('B'), err = val('C');\nconst shimColor = err > 1 ? '#ef4444' : (err > 0.1 ? '#f59e0b' : '#22c55e');\nconst fmt = n => n >= 1000 ? (n/1000).toFixed(1)+'k' : n.toFixed(1);\nconst w = v => Math.max(2, Math.min(14, v/2));\nreturn {\n  backgroundColor: 'transparent',\n  tooltip: { formatter: p => p.dataType === 'edge' ? (p.data.lbl||'') : p.name },\n  series: [{\n    type: 'graph', layout: 'none', roam: true,\n    label: { show: true, color: '#e5e7eb', position: 'bottom', fontSize: 13 },\n    edgeLabel: { show: true, color: '#cbd5e1', fontSize: 12, formatter: p => p.data.lbl },\n    edgeSymbol: ['none','arrow'], edgeSymbolSize: 12,\n    data: [\n      { name: 'Client (Geode)', x: 120, y: 200, symbolSize: 64, itemStyle: { color: '#6366f1' } },\n      { name: 'ProtoGemCouch Shim', x: 430, y: 200, symbolSize: 92, itemStyle: { color: shimColor } },\n      { name: 'Couchbase / N1QL', x: 760, y: 200, symbolSize: 64, itemStyle: { color: '#ef4444' } }\n    ],\n    links: [\n      { source: 'Client (Geode)', target: 'ProtoGemCouch Shim', lbl: fmt(reqps)+' req/s',\n        lineStyle: { color: '#22c55e', width: w(reqps), curveness: 0 } },\n      { source: 'ProtoGemCouch Shim', target: 'Couchbase / N1QL', lbl: fmt(pushed)+' pushed/s',\n        lineStyle: { color: '#38bdf8', width: w(pushed), curveness: 0 } }\n    ]\n  }]\n};\n"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "geomap",
      "title": "Global regions (ILLUSTRATIVE \u2014 synthetic; single-region deployment)",
      "datasource": {
        "type": "grafana-testdata-datasource",
        "uid": "testdata"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-testdata-datasource",
            "uid": "testdata"
          },
          "refId": "A",
          "scenarioId": "csv_content",
          "csvContent": "latitude,longitude,name,latency_ms\n45.84,-119.70,us-west-2,34\n38.13,-78.45,us-east-1,23\n53.41,-8.24,eu-west-1,41\n1.35,103.82,ap-southeast-1,67\n-33.87,151.21,ap-southeast-2,38\n"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "red",
                "value": 200
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "view": {
          "id": "coords",
          "lat": 25,
          "lon": 10,
          "zoom": 1.4
        },
        "basemap": {
          "type": "default",
          "name": "Basemap"
        },
        "controls": {
          "showZoom": true,
          "mouseWheelZoom": true,
          "showAttribution": true
        },
        "tooltip": {
          "mode": "details"
        },
        "layers": [
          {
            "type": "markers",
            "name": "Regions",
            "location": {
              "mode": "auto"
            },
            "config": {
              "style": {
                "size": {
                  "fixed": 10,
                  "field": "latency_ms",
                  "min": 8,
                  "max": 22
                },
                "color": {
                  "field": "latency_ms"
                },
                "opacity": 0.85,
                "symbol": {
                  "fixed": "img/icons/marker/circle.svg"
                },
                "textConfig": {
                  "fontSize": 11,
                  "offsetY": -14
                }
              },
              "showLegend": true
            },
            "tooltip": true
          }
        ]
      }
    },
    {
      "id": 9,
      "type": "heatmap",
      "title": "Latency heatmap (all operations)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "expr": "sum(rate(protogemcouch_operation_latency_seconds_bucket[$__rate_interval])) by (le)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "scheme": "Spectral",
          "mode": "scheme"
        },
        "yAxis": {
          "unit": "s"
        }
      }
    },
    {
      "id": 10,
      "type": "state-timeline",
      "title": "Service health by operation (green=ok, red=errors)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "legendFormat": "{{operation}}",
          "expr": "clamp_max(sum by (operation) (rate(protogemcouch_operation_errors_total[$__rate_interval])), 1)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.0001
              }
            ]
          },
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0
          }
        },
        "overrides": []
      },
      "options": {
        "mergeValues": true,
        "showValue": "never",
        "rowHeight": 0.9,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Request rate by operation",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (operation) (rate(protogemcouch_operation_requests_total[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{operation}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "logs",
      "title": "Recent shim logs (Loki)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "refId": "A",
          "expr": "{container=\"protogemcouch-shim\"}",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": false,
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ]
}