{
  "uid": "protogemcouch-observability",
  "title": "ProtoGemCouch Observability",
  "tags": ["protogemcouch", "geode", "couchbase"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "operation",
        "label": "Operation",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(protogemcouch_operation_requests_total, operation)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Request rate (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(protogemcouch_operation_requests_total{operation=~\"$operation\"}[$__rate_interval]))" } ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error rate (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.001 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(protogemcouch_operation_errors_total{operation=~\"$operation\"}[$__rate_interval]))" } ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(protogemcouch_connections_opened_total) - sum(protogemcouch_connections_closed_total)" } ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Unknown opcodes (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "textMode": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(protogemcouch_unknown_opcodes_total)" } ]
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Request rate by operation",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never", "stacking": { "mode": "none" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (operation) (rate(protogemcouch_operation_requests_total{operation=~\"$operation\"}[$__rate_interval]))", "legendFormat": "{{operation}}" } ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Error rate by operation",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never", "stacking": { "mode": "normal" } }, "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (operation) (rate(protogemcouch_operation_errors_total{operation=~\"$operation\"}[$__rate_interval]))", "legendFormat": "{{operation}}" } ]
    },

    {
      "id": 12,
      "type": "timeseries",
      "title": "p95 latency by operation",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 0, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (operation, le) (rate(protogemcouch_operation_latency_seconds_bucket{operation=~\"$operation\"}[$__rate_interval])))", "legendFormat": "{{operation}}" } ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "p99 latency by operation",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 0, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (operation, le) (rate(protogemcouch_operation_latency_seconds_bucket{operation=~\"$operation\"}[$__rate_interval])))", "legendFormat": "{{operation}}" } ]
    },

    {
      "id": 14,
      "type": "timeseries",
      "title": "Overall latency percentiles (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 5, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(protogemcouch_operation_latency_seconds_bucket{operation=~\"$operation\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(protogemcouch_operation_latency_seconds_bucket{operation=~\"$operation\"}[$__rate_interval])))", "legendFormat": "p95" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(protogemcouch_operation_latency_seconds_bucket{operation=~\"$operation\"}[$__rate_interval])))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Response throughput by operation",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (operation) (rate(protogemcouch_operation_response_bytes_total{operation=~\"$operation\"}[$__rate_interval]))", "legendFormat": "{{operation}}" } ]
    },

    {
      "id": 16,
      "type": "timeseries",
      "title": "Max response payload by operation",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 0, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max by (operation) (protogemcouch_operation_response_bytes_max{operation=~\"$operation\"})", "legendFormat": "{{operation}}" } ]
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Request throughput by operation",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (operation) (rate(protogemcouch_operation_request_bytes_total{operation=~\"$operation\"}[$__rate_interval]))", "legendFormat": "{{operation}}" } ]
    },

    {
      "id": 18,
      "type": "timeseries",
      "title": "Connection churn",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(protogemcouch_connections_opened_total[$__rate_interval])", "legendFormat": "opened/s" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(protogemcouch_connections_closed_total[$__rate_interval])", "legendFormat": "closed/s" }
      ]
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Handshake & unknown-opcode rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(protogemcouch_handshake_requests_total[$__rate_interval])", "legendFormat": "handshakes/s" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(protogemcouch_unknown_opcodes_total[$__rate_interval])", "legendFormat": "unknown opcodes/s" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(protogemcouch_request_errors_total[$__rate_interval])", "legendFormat": "request errors/s" }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "PDX & subscription registry sizes",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "protogemcouch_pdx_types", "legendFormat": "PDX types" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "protogemcouch_pdx_enums", "legendFormat": "PDX enums" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "protogemcouch_registered_interests", "legendFormat": "interests" },
        { "refId": "D", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "protogemcouch_registered_cqs", "legendFormat": "CQs" }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Transactions, feeds & durable queue",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "protogemcouch_active_transactions", "legendFormat": "active transactions" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "protogemcouch_subscription_feeds", "legendFormat": "subscription feeds" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "protogemcouch_durable_clients", "legendFormat": "durable clients" },
        { "refId": "D", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "protogemcouch_durable_queue_depth", "legendFormat": "durable queue depth" }
      ]
    },

    {
      "id": 29,
      "type": "text",
      "title": "Breakdowns, distributions & availability",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 52 },
      "options": {
        "mode": "markdown",
        "content": "The panels below complement the time-series above with **non-time-series** views: a **bar gauge** and **pie chart** compare per-operation load side by side, a **gauge** tracks the error ratio against an SLO, a **heatmap** shows the latency distribution over time, a **bar chart** ranks tail latency by operation, a **table** summarizes each operation, and a **state-timeline** shows scrape-target availability. See [docs/OBSERVABILITY.md](https://github.com/rhadaway14/proto-gemcouch/blob/master/docs/OBSERVABILITY.md)."
      }
    },
    {
      "id": 30,
      "type": "bargauge",
      "title": "Request rate by operation",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 55 },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "continuous-GrYlRd" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (operation) (rate(protogemcouch_operation_requests_total{operation=~\"$operation\"}[$__rate_interval]))", "legendFormat": "{{operation}}", "instant": true } ]
    },
    {
      "id": 31,
      "type": "piechart",
      "title": "Traffic share by operation",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 55 },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "pieType": "donut", "legend": { "displayMode": "list", "placement": "right", "values": ["percent"] }, "tooltip": { "mode": "single" }, "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (operation) (rate(protogemcouch_operation_requests_total{operation=~\"$operation\"}[$__rate_interval]))", "legendFormat": "{{operation}}", "instant": true } ]
    },
    {
      "id": 32,
      "type": "gauge",
      "title": "Error ratio (errors / requests)",
      "description": "Percentage of operations that failed over the dashboard range. Amber/red thresholds mark the error-rate SLO.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 55 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 } ] } }, "overrides": [] },
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true, "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "100 * sum(rate(protogemcouch_operation_errors_total[$__rate_interval])) / clamp_min(sum(rate(protogemcouch_operation_requests_total[$__rate_interval])), 1)", "instant": true } ]
    },
    {
      "id": 33,
      "type": "heatmap",
      "title": "Operation latency distribution (heatmap)",
      "description": "Latency buckets over time — bands reveal how the p95/p99 distribution shifts under load, which percentile lines alone hide.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 63 },
      "fieldConfig": { "defaults": { "custom": { "scaleDistribution": { "type": "linear" }, "hideFrom": { "tooltip": false, "viz": false, "legend": false } } }, "overrides": [] },
      "options": { "calculate": false, "cellGap": 1, "color": { "mode": "scheme", "scheme": "Spectral", "reverse": false, "steps": 64, "exponent": 0.5, "fill": "dark-orange" }, "yAxis": { "axisPlacement": "left", "unit": "s" }, "rowsFrame": { "layout": "auto" }, "tooltip": { "mode": "single", "yHistogram": true }, "legend": { "show": true }, "exemplars": { "color": "rgba(255,0,255,0.7)" }, "filterValues": { "le": 1e-9 } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (le) (rate(protogemcouch_operation_latency_seconds_bucket{operation=~\"$operation\"}[$__rate_interval]))", "legendFormat": "{{le}}", "format": "heatmap" } ]
    },
    {
      "id": 34,
      "type": "barchart",
      "title": "p99 latency by operation",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 63 },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "orientation": "horizontal", "xField": "operation", "showValue": "auto", "stacking": "none", "legend": { "showLegend": false }, "tooltip": { "mode": "single" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (operation, le) (rate(protogemcouch_operation_latency_seconds_bucket{operation=~\"$operation\"}[$__rate_interval])))", "legendFormat": "{{operation}}", "instant": true, "format": "table" } ],
      "transformations": [ { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "p99" } } } ]
    },
    {
      "id": 35,
      "type": "table",
      "title": "Per-operation summary (rate / errors / p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 71 },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "filterable": true } }, "overrides": [ { "matcher": { "id": "byName", "options": "p99 (s)" }, "properties": [ { "id": "unit", "value": "s" } ] }, { "matcher": { "id": "byName", "options": "req/s" }, "properties": [ { "id": "unit", "value": "reqps" } ] }, { "matcher": { "id": "byName", "options": "err/s" }, "properties": [ { "id": "unit", "value": "reqps" }, { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.001 } ] } } ] } ] },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "req/s", "desc": true } ] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (operation) (rate(protogemcouch_operation_requests_total{operation=~\"$operation\"}[$__rate_interval]))", "instant": true, "format": "table" },
