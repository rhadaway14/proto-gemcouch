{
  "uid": "protogemcouch-logs-traces",
  "title": "ProtoGemCouch Logs & Traces",
  "tags": ["protogemcouch", "logs", "traces"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "label": "Shim container",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "container", "stream": "", "type": 1 },
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "current": { "text": "protogemcouch-shim", "value": "protogemcouch-shim" },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Logs (Loki)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Log volume by level",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "logs", "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" }, "fillOpacity": 60 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level) (count_over_time({container=\"$container\"} [$__interval]))",
          "legendFormat": "{{level}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Completed operations by type (per second)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (operation) (rate({container=\"$container\"} | logfmt | event=\"request_completed\" [$__rate_interval]))",
          "legendFormat": "{{operation}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Failed requests & malformed frames (per second)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 20 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(rate({container=\"$container\"} | logfmt | event=\"request_failed\" [$__rate_interval]))",
          "legendFormat": "request_failed"
        },
        {
          "refId": "B",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(rate({logger=\"protogemcouch.audit\"} | logfmt | event=\"malformed_frame\" [$__rate_interval]))",
          "legendFormat": "malformed_frame"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Audit events by type",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 60 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (event) (count_over_time({logger=\"protogemcouch.audit\"} | logfmt [$__interval]))",
          "legendFormat": "{{event}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "PDX registry cap rejections by kind (per minute)",
      "description": "Rate of pdx_registry_cap_exceeded audit events, split by registry kind (types/enums). Non-zero means a client tried to register past MAX_PDX_TYPES/MAX_PDX_ENUMS — see the matching Prometheus alert ProtoGemCouchPdxRegistryRejections.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 60 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (kind) (count_over_time({logger=\"protogemcouch.audit\"} | logfmt | event=\"pdx_registry_cap_exceeded\" [1m]))",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Shim logs (live)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 22 },
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending", "dedupStrategy": "none" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{container=\"$container\"}"
        }
      ]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Security audit stream",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 22 },
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending", "dedupStrategy": "none" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{logger=\"protogemcouch.audit\"}"
        }
      ]
    },
    {
      "id": 8,
      "type": "row",
      "title": "Traces (Jaeger) — requires the docker-compose.tracing.yml overlay",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Recent traces",
      "description": "Recent operation traces from Jaeger. Click a trace ID to open the full span tree in Explore.",
      "datasource": { "type": "jaeger", "uid": "jaeger" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 33 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "jaeger", "uid": "jaeger" },
          "queryType": "search",
          "service": "protogemcouch"
        }
      ]
    }
  ]
}
