      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 16,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "expr": "sum(rate(protogemcouch_operation_requests_total[$__rate_interval]))",
          "instant": true,
          "legendFormat": "reqps"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "B",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(protogemcouch_operation_latency_seconds_bucket{opcode=\"34\"}[$__rate_interval]))) * 1000",
          "instant": true,
          "legendFormat": "p99"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "C",
          "expr": "sum(rate(protogemcouch_pushdown_queries_total{result=\"pushed\"}[5m])) / clamp_min(sum(rate(protogemcouch_pushdown_queries_total[5m])), 1) * 100",
          "instant": true,
          "legendFormat": "hit"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "D",
          "expr": "sum(protogemcouch_connections_opened_total) - sum(protogemcouch_connections_closed_total)",
          "instant": true,
          "legendFormat": "conns"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "E",
          "expr": "sum(protogemcouch_pushdown_queries_total{result=\"pushed\"})",
