# Perf-gate thresholds for a DEDICATED, representative environment (the capacity rig) — the tight
# counterpart to the conservative CI defaults in perf-baseline.env. Enforce these only on controlled
# hardware where run-to-run variance is small; on a shared CI runner they WILL flake.
#
# Usage (from a host that can reach the shim, with the jar built):
#   PERF_BASELINE=scripts/perf-baseline.rig.env \
#   PERF_HOST=<shim-ip> ./scripts/perf-gate.sh
#
# Calibrated to the 2026-06-19 rig run (docs/SOAK_RESULTS.md): a single shim on c6i.xlarge (4 vCPU),
# dedicated Couchbase r6i.xlarge, read-heavy KV hot path, sustained ~16.9k ops/sec at GET p99 ~4.3 ms,
# 0 errors. The thresholds below sit a safe margin under/over those so a healthy shim clears them while
# a real regression (a third of the throughput, or a several-fold tail-latency blow-up) trips the gate.

# --- benchmark run parameters (match the rig read-heavy characterization) ---
PERF_PROFILE="${PERF_PROFILE:-read-heavy}"
PERF_CONCURRENCY="${PERF_CONCURRENCY:-32}"
PERF_WARMUP_SECONDS="${PERF_WARMUP_SECONDS:-15}"
PERF_DURATION_SECONDS="${PERF_DURATION_SECONDS:-60}"
PERF_KEYSPACE="${PERF_KEYSPACE:-100000}"
PERF_SEED_COUNT="${PERF_SEED_COUNT:-100000}"

# --- gate thresholds (tight; dedicated environment only) ---
# Floor ~70% of the measured 16.9k ceiling — clears comfortably when healthy, trips on a real regression.
PERF_MIN_OPS_PER_SEC="${PERF_MIN_OPS_PER_SEC:-12000}"
# Ceiling ~2.3x the measured 4.3 ms GET p99 — absorbs normal jitter, trips on a tail-latency blow-up.
PERF_MAX_P99_MS="${PERF_MAX_P99_MS:-10}"
# A clean run reports zero operation errors.
PERF_MAX_ERRORS="${PERF_MAX_ERRORS:-0}"
