# Perf-gate thresholds for the QUERY-WEIGHTED gate (sourced by scripts/perf-gate.sh). Runs the
# query-heavy profile with queryable values against a pushdown-enabled shim, so it exercises and guards
# the OQL pushdown query path (not CRUD). Use it via:
#
#   PERF_BASELINE=scripts/perf-baseline.query.env PERF_SHIM_PORT=40414 PERF_HEALTH_PORT=8090 \
#     bash scripts/perf-gate.sh
#
# Reference local run (dockerized Couchbase, 8 workers, 2000-key region, indexed pushdown):
#   pushdown ON ~150 ops/sec, query p99 ~100 ms, 0 errors — vs the full-region scan (pushdown off) at
#   ~25 ops/sec, query p99 ~490 ms (a ~6x throughput / ~5x tail-latency win). Thresholds below are the
#   CONSERVATIVE CI guards (tolerate slow/noisy runners); the rig file enforces tight query p99.

# --- benchmark run parameters ---
PERF_PROFILE="${PERF_PROFILE:-query-heavy}"
PERF_QUERYABLE_VALUES="${PERF_QUERYABLE_VALUES:-true}"
PERF_CONCURRENCY="${PERF_CONCURRENCY:-8}"
PERF_WARMUP_SECONDS="${PERF_WARMUP_SECONDS:-8}"
PERF_DURATION_SECONDS="${PERF_DURATION_SECONDS:-20}"
PERF_KEYSPACE="${PERF_KEYSPACE:-2000}"
PERF_SEED_COUNT="${PERF_SEED_COUNT:-2000}"

# --- gate thresholds ---
# Each query filters + frames a result, so per-op throughput is far below the KV hot path; the floor is
# correspondingly low. It is set above the full-scan rate (~25 ops/sec local), so if pushdown silently
# regressed to a scan the throughput would drop below this floor and trip the gate.
PERF_MIN_OPS_PER_SEC="${PERF_MIN_OPS_PER_SEC:-25}"
# Worst-operation p99 (ms): a gross-regression ceiling that tolerates slow CI runners.
PERF_MAX_P99_MS="${PERF_MAX_P99_MS:-2000}"
# QUERY-operation p99 (ms): conservative CI ceiling for the query tail. The tight, SLO-grade query p99
# enforcement lives in perf-baseline.rig.env (PERF_MAX_QUERY_P99_MS) for dedicated hardware.
PERF_MAX_QUERY_P99_MS="${PERF_MAX_QUERY_P99_MS:-1000}"
# A clean run reports zero operation errors.
PERF_MAX_ERRORS="${PERF_MAX_ERRORS:-0}"
