# Perf-regression gate thresholds + run parameters (sourced by scripts/perf-gate.sh).
#
# These are deliberately CONSERVATIVE gross-regression guards, not tight SLOs. They catch a large
# performance regression — a change that tanks throughput or blows up tail latency — while tolerating
# the wide run-to-run variance of shared CI runners and dev machines, so the gate does not flake.
# Tighten them only against a representative, dedicated environment (see docs/PERFORMANCE_BASELINE.md).
#
# Reference local baseline (dockerized Couchbase, 16 workers, mixed profile, 20s measured):
#   ~6200 ops/sec, worst-operation p99 ~150ms, 0 errors.

# All values use ${VAR:-default} so any of them can be overridden from the environment (the gate
# script sources this file, and an env var set before it wins).

# --- benchmark run parameters ---
PERF_PROFILE="${PERF_PROFILE:-mixed}"
PERF_CONCURRENCY="${PERF_CONCURRENCY:-16}"
PERF_WARMUP_SECONDS="${PERF_WARMUP_SECONDS:-10}"
PERF_DURATION_SECONDS="${PERF_DURATION_SECONDS:-20}"
PERF_KEYSPACE="${PERF_KEYSPACE:-2000}"
PERF_SEED_COUNT="${PERF_SEED_COUNT:-2000}"

# --- gate thresholds ---
# Minimum measured throughput. Floor is ~1/6 of the local baseline so a healthy shim clears it even on
# a much slower CI runner, while a several-fold throughput regression trips it.
PERF_MIN_OPS_PER_SEC="${PERF_MIN_OPS_PER_SEC:-1000}"
# Maximum worst-operation p99 latency (ms). ~6x the local baseline p99 — tolerates slow runners but
# trips on a large tail-latency regression.
PERF_MAX_P99_MS="${PERF_MAX_P99_MS:-1000}"
# A clean benchmark run must report zero operation errors.
PERF_MAX_ERRORS="${PERF_MAX_ERRORS:-0}"
